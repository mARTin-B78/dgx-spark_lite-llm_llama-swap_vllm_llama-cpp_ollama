#  "ikiru/dolphin-mistral-24b-venice-edition:latest":
#    ttl: 0
#    checkEndpoint: "/"
#    cmd: >
#      docker run --rm --name ollama-dolphin-${PORT}
#      --runtime nvidia --gpus all --network container:llama-swap
#      -e OLLAMA_HOST=0.0.0.0:${PORT}
#      -v ${env.LLM_ROOT_PATH}/ollama:/root/.ollama
#      ollama/ollama:latest
#      serve
#    cmdStop: "docker stop ollama-dolphin-${PORT}"

# --- Persistent llama.cpp Models ---
# Note: These point to your existing server on port 18080
  

#  NVIDIA-Nemotron3-Nano-4B-Q4_K_M:
#    endpoint: "http://127.0.0.1:18080"
#
#  Qwen3.5-35B-A3B-Uncensored-HauhauCS-Aggressive:
#    endpoint: "http://127.0.0.1:18080"


  # --- VLLM MODELS ---
  # --- DeepSeek V4 Flash IQ2XXS (DS4 GGUF server) ---
  # Start host server with: ./scripts/start-ds4-deepseek.sh
#  DeepSeek-V4-Flash-IQ2XXS-DS4:
#    cmd: "sleep infinity"
#    proxy: "http://192.168.178.8:18004"
#    checkEndpoint: "none"
#    ttl: 0

  # --- spark-arena winner recipe: vllm-node-tf5 + Mamba float16 + large batches ---
  # Adaptive gmem via launch-vllm-auto.sh. Set GMEM_OVERRIDE=0.40 to pin static.
  Qwen3.5-35B-A3B-FP8:
    ttl: 0
    readyTimeout: 600
    checkEndpoint: "/health"
    cmd: >
      env
      MODEL_PATH=/models/vllm/Qwen/Qwen3.5-35B-A3B-FP8
      MODEL_HOST_PATH=/models/vllm/Qwen/Qwen3.5-35B-A3B-FP8
      CONTAINER_NAME=vllm-qwen3.5-35b-${PORT}
      IMAGE=vllm-node-tf5:latest
      PORT=${PORT} HOST=${host}
      MAX_MODEL_LEN=131072 MAX_NUM_SEQS=10 KV_DTYPE_BYTES=1
      GMEM_MIN=0.40 GMEM_MAX=0.75 SAFETY_GIB=4
      /app/scripts/launch-vllm-auto.sh
      --served-model-name Qwen3.5-35B-A3B-FP8
      --chat-template /models/vllm/Qwen/Qwen3.5-35B-A3B-FP8/chat_template.jinja
      --max-num-batched-tokens 32768
      --max-cudagraph-capture-size 10
      --kv-cache-dtype fp8
      --load-format fastsafetensors
      --attention-backend FLASHINFER
      --enable-prefix-caching
      --trust-remote-code
      --mamba-ssm-cache-dtype float16
      --enable-auto-tool-choice
      --tool-call-parser qwen3_coder
      --reasoning-parser qwen3
    cmdStop: "docker stop vllm-qwen3.5-35b-${PORT}"

  # --- Qwen3.6: same arch as 3.5, upgraded MoE — no MTP (degrades perf) ---
  # Thermals: previous cfg (262k ctx, 32k batched tokens, gmax 0.85) drove the
  # GB10 into thermal shutdown under sustained load. Reduced to 131k ctx,
  # 16k batched tokens, gmax 0.75 to cap sustained power draw.
  # --- Qwen3.6: same arch as 3.5, upgraded MoE — MTP Optimized ---
  # Optimized settings from NVIDIA Forums & Spark Arena
  # Speculative Decoding: MTP (1 token), Context: 256k
  # NOTE: GMEM_OVERRIDE=0.7069 keeps the hand-tuned thermal cap. Set to
  # "adaptive" (or remove the line) to let the launcher compute it. Image
  # vllm/vllm-openai has `vllm serve` as ENTRYPOINT → VLLM_SERVE_PREFIX="".
  Qwen3.6-35B-A3B-FP8:
    ttl: 0
    readyTimeout: 600
    checkEndpoint: "/health"
    cmd: >
      env
      MODEL_PATH=/models/vllm/Qwen/Qwen3.6-35B-A3B-FP8
      MODEL_HOST_PATH=/models/vllm/Qwen/Qwen3.6-35B-A3B-FP8
      CONTAINER_NAME=vllm-qwen3.6-35b-${PORT}
      IMAGE=vllm-node:latest
      PORT=${PORT} HOST=${host}
      MAX_MODEL_LEN=262144 MAX_NUM_SEQS=20 KV_DTYPE_BYTES=1
      GMEM_OVERRIDE=0.7069
      GMEM_MIN=0.55 GMEM_MAX=0.71 SAFETY_GIB=4
      EXTRA_DOCKER_ARGS="-e PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True -e OMP_NUM_THREADS=4"
      /app/scripts/launch-vllm-auto.sh
      --served-model-name Qwen3.6-35B-A3B-FP8 qwen3.6-35b-a3b
      --chat-template /models/vllm/Qwen/Qwen3.6-35B-A3B-FP8/chat_template.jinja
      --max-num-batched-tokens 32768
      --attention-backend flashinfer
      --kv-cache-dtype fp8
      --enable-prefix-caching
      --reasoning-parser qwen3
      --enable-auto-tool-choice
      --tool-call-parser qwen3_coder
      --speculative-config '{"method":"mtp","num_speculative_tokens":1}'
      --trust-remote-code
    cmdStop: "docker stop vllm-qwen3.6-35b-${PORT}"

  # --- Qwen3.6-27B PrismaSCOUT (Blackwell NVFP4+BF16 mixed, compressed-tensors) ---
  # ~20 GiB weights, GSM8K 96.66%, MTP speculative decoding k=1.
  # Architecture: 64 hybrid layers (16 full GDN attention @ full_attention_interval=4
  # + 48 linear/Mamba layers). KV cache only for the 16 attention layers.
  #
  # ⚠️  YAML blank-line gotcha: a blank line inside a `>` folded block scalar
  # becomes a literal \n. When the shell receives the split command, the first
  # `env VAR=val ...` line runs as a no-op (env without a command just prints
  # the environment) and none of MAX_MODEL_LEN / MAX_NUM_SEQS / GMEM_* reach
  # the launch script. vLLM then auto-detects max_model_len=262144 from
  # config.json → 81 GiB KV cache → OOM crash. All env vars must be on
  # consecutive non-blank lines. Fixed here.
  #
  # CUDA_MANAGED_FORCE_DEVICE_ALLOC=1 removed: unsafe on GB10 unified memory.
  # Reliable-load profile:
  #   - 32K context + 2 seqs keeps KV/cache pressure low on GB10 unified memory.
  #   - enforce-eager avoids the long CUDA graph capture/autotune path that can
  #     over-allocate with spec-decode on this hybrid/Mamba architecture.
  #   - MTP/DFlash can be re-enabled later as a speed profile once base load is
  #     boringly reliable.
  Qwen3.6-27B-PrismaSCOUT-NVFP4:
    ttl: 0
    readyTimeout: 600
    checkEndpoint: "/health"
    cmd: >
      env
      MODEL_PATH=/models/vllm/rdtand/Qwen3.6-27B-PrismaSCOUT-Blackwell-NVFP4-BF16-vllm
      MODEL_HOST_PATH=/models/vllm/rdtand/Qwen3.6-27B-PrismaSCOUT-Blackwell-NVFP4-BF16-vllm
      CONTAINER_NAME=vllm-qwen3.6-27b-${PORT}
      IMAGE=vllm-node:latest
      PORT=${PORT} HOST=${host}
      MAX_MODEL_LEN=32768 MAX_NUM_SEQS=1 KV_DTYPE_BYTES=1
      GMEM_MIN=0.30 GMEM_MAX=0.36 SAFETY_GIB=4
      EXTRA_DOCKER_ARGS='-e NVIDIA_FORWARD_COMPAT=1 -e VLLM_MARLIN_USE_ATOMIC_ADD=1 -e FLASHINFER_DISABLE_VERSION_CHECK=1 -e TORCH_MATMUL_PRECISION=high -e VLLM_TEST_FORCE_FP8_MARLIN=1 -e PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True -e OMP_NUM_THREADS=4'
      /app/scripts/launch-vllm-auto.sh
      --served-model-name Qwen3.6-27B-PrismaSCOUT-NVFP4 qwen3.6-27b
      --chat-template /models/vllm/rdtand/Qwen3.6-27B-PrismaSCOUT-Blackwell-NVFP4-BF16-vllm/chat_template.jinja
      --language-model-only
      --max-num-batched-tokens 4096
      --quantization compressed-tensors
      --kv-cache-dtype fp8
      --load-format fastsafetensors
      --enable-prefix-caching
      --enable-chunked-prefill
      --enforce-eager
      --no-enable-flashinfer-autotune
      --trust-remote-code
      --reasoning-parser qwen3
      --enable-auto-tool-choice
      --tool-call-parser qwen3_coder
    cmdStop: "docker stop vllm-qwen3.6-27b-${PORT}"

  # --- forum-tuned: mamba float16 + large batches + FP8 KV cache ---
  # Uses a launcher script that queries free VRAM at launch time and sets
  # gpu_memory_utilization dynamically (max 0.85, min 0.60) so vLLM's startup
  # sanity check never fails due to residual CUDA memory from previous containers.
  Qwen3.5-122B-A10B-int4-AutoRound:
    ttl: 0
    readyTimeout: 1800
    checkEndpoint: "/health"
    cmd: /app/scripts/launch-qwen35-122b.sh ${PORT} ${host}
    cmdStop: "docker stop vllm-qwen3.5-122b-${PORT}"

  # --- Works - is for Visual Stuff with Pictures ---
  Qwen3-VL-30B-A3B-Instruct-FP8:
    ttl: 0
    readyTimeout: 600
    checkEndpoint: "/health"
    cmd: >
      env
      MODEL_PATH=/models/vllm/Qwen/Qwen3-VL-30B-A3B-Instruct-FP8
      MODEL_HOST_PATH=/models/vllm/Qwen/Qwen3-VL-30B-A3B-Instruct-FP8
      CONTAINER_NAME=vllm-qwen3-vl-${PORT}
      IMAGE=vllm-node:latest
      PORT=${PORT} HOST=${host}
      MAX_MODEL_LEN=32768 MAX_NUM_SEQS=10 KV_DTYPE_BYTES=1
      GMEM_MIN=0.40 GMEM_MAX=0.65 SAFETY_GIB=4
      /app/scripts/launch-vllm-auto.sh
      --served-model-name Qwen3-VL-30B-A3B-Instruct-FP8
      --trust-remote-code
      --limit-mm-per-prompt '{"image": 2}'
      --kv-cache-dtype fp8
      --load-format fastsafetensors
      --enable-prefix-caching
      --tensor-parallel-size 1
      --enable-auto-tool-choice
      --tool-call-parser hermes
    cmdStop: "docker stop vllm-qwen3-vl-${PORT}"

  # --- Works - is for Pictures, Sound, Text ---
  # Qwen3-Omni 30B BF16 multimodal — weights ~60 GiB, KV ~6 GiB at 32K.
  # Static --gpu-memory-utilization 0.40 (~49 GiB) was below weights → KV ValueError.
  # Switched to launch-vllm-auto.sh: GMEM_MIN=0.60, GMEM_MAX=0.75.
  #
  # BROKEN (vllm-node:latest, June-2026 build): meta tensor device mismatch in
  # qwen3_omni_moe_thinker.py during _dummy_run memory profiling. A positional
  # buffer stays on meta device and crashes prims.add at forward:1121. Neither
  # --enforce-eager, --load-format auto, nor limit-mm-per-prompt workarounds help.
#  Qwen3-Omni-30B-A3B-Instruct:
#    ttl: 0
#    readyTimeout: 600
#    checkEndpoint: "/health"
#    cmd: >
#      env
#      MODEL_PATH=/models/vllm/Qwen/Qwen3-Omni-30B-A3B-Instruct
#      MODEL_HOST_PATH=/models/vllm/Qwen/Qwen3-Omni-30B-A3B-Instruct
#      CONTAINER_NAME=vllm-qwen3-omni-${PORT}
#      IMAGE=vllm-node:latest
#      PORT=${PORT} HOST=${host}
#      MAX_MODEL_LEN=32768 MAX_NUM_SEQS=10 KV_DTYPE_BYTES=2
#      GMEM_MIN=0.60 GMEM_MAX=0.75 SAFETY_GIB=6
#      /app/scripts/launch-vllm-auto.sh
#      --served-model-name Qwen3-Omni-30B-A3B-Instruct
#      --trust-remote-code
#      --limit-mm-per-prompt '{"image": 2, "audio": 2}'
#      --load-format fastsafetensors
#      --enable-prefix-caching
#      --tensor-parallel-size ${tensor_parallel}
#      --enable-auto-tool-choice
#      --tool-call-parser hermes
#    cmdStop: "docker stop vllm-qwen3-omni-${PORT}"

  # --- is for Coding (Qwen3-Next ~480B-A22B, FP8 Dynamic) ---
  # Weights ≈ 77.8 GiB. Static gmem 0.90 (109 GiB) failed when free VRAM
  # was below the cap. Switched to launch-vllm-auto.sh + PRE_LAUNCH_CMD
  # (runs the mod patch revert before vllm starts). Auto-fits to free VRAM.
  #
  # CONTEXT-LENGTH CHOICE — pick one:
  #
  # (A) 128k context, always loadable (current setting):
  #       MAX_MODEL_LEN=131072 GMEM_MIN=0.73
  #     Plenty for OpenClaw's typical 28k bootstraps. Loads cleanly even
  #     mid-benchmark when page cache is high. SAFE DEFAULT.
  #
  # (B) 256k context, only loadable when memory is fresh:
  #       MAX_MODEL_LEN=262144 GMEM_MIN=0.77
  #     Needs MemFree ≥ ~94 GiB (78 GiB weights + 10.5 GiB KV for one
  #     256k sequence + 5 GiB activations + buffer). After several model
  #     swaps the page cache holds 30-40 GiB that /proc/meminfo reports
  #     as "Available" but vLLM's cudaMemGetInfo can't see. Mid-benchmark
  #     loads fail-fast (clean error, not a crash). For interactive
  #     OpenClaw use after a fresh stack restart, works without help.
  #     If it fails to load mid-benchmark and you need it, run:
  #         sudo sysctl vm.drop_caches=3 && docker restart llama-swap
  #
  # If you switch to (B), also bump OpenClaw's
  # ~/.openclaw/openclaw.json -> contextWindow: 262144
  Qwen3-Coder-Next-FP8-Dynamic:
    ttl: 0
    readyTimeout: 1200
    checkEndpoint: "/health"
    cmd: >
      env
      MODEL_PATH=/models/vllm/unsloth/Qwen3-Coder-Next-FP8-Dynamic
      MODEL_HOST_PATH=/models/vllm/unsloth/Qwen3-Coder-Next-FP8-Dynamic
      CONTAINER_NAME=vllm-qwen3-coder-${PORT}
      IMAGE=vllm-node-tf5:latest
      PORT=${PORT} HOST=${host}
      MAX_MODEL_LEN=131072 MAX_NUM_SEQS=4 KV_DTYPE_BYTES=1
      GMEM_MIN=0.73 GMEM_MAX=0.92 SAFETY_GIB=8
      EXTRA_DOCKER_ARGS="-e VLLM_ALLOW_LONG_MAX_MODEL_LEN=1 -e VLLM_MEMORY_PROFILER_ESTIMATE_CUDAGRAPHS=1 -v ${env.REPO_CONFIG_PATH}/vllm/build/spark-vllm-docker/mods/fix-qwen3-next-autoround:/mod:ro"
      PRE_LAUNCH_CMD='cd /mod && bash run.sh'
      /app/scripts/launch-vllm-auto.sh
      --served-model-name Qwen3-Coder-Next-FP8-Dynamic
      --chat-template /models/vllm/unsloth/Qwen3-Coder-Next-FP8-Dynamic/chat_template.jinja
      --kv-cache-dtype fp8
      --load-format fastsafetensors
      --attention-backend flashinfer
      --enable-prefix-caching
      --enable-chunked-prefill
      --max-num-batched-tokens 16384
      --enable-auto-tool-choice
      --tool-call-parser qwen3_coder
    cmdStop: "docker stop vllm-qwen3-coder-${PORT}"

  # --- Optimized: INT4 AutoRound, spark-arena v2 recipe ---
  # Static gmem 0.40 (~49 GiB) was tight after weights+KV. Now uses
  # launch-vllm-auto.sh + PRE_LAUNCH_CMD for the mod patch.
  #
  # CONTEXT: 32k only. Bumping MAX_MODEL_LEN to 131k caused incoherent
  # output ("!!!!" floods) — the int4 AutoRound calibration was done at
  # short context, and `--optimization-level 3 --performance-mode
  # throughput --kv-cache-dtype fp8` at long context pushes numeric
  # precision past the breaking point. For long-context coding, use the
  # FP8-Dynamic variant instead (128k coherent).
  Qwen3-Coder-Next-int4-AutoRound:
    ttl: 0
    readyTimeout: 1200
    checkEndpoint: "/health"
    cmd: >
      env
      MODEL_PATH=/models/vllm/Intel/Qwen3-Coder-Next-int4-AutoRound
      MODEL_HOST_PATH=/models/vllm/Intel/Qwen3-Coder-Next-int4-AutoRound
      CONTAINER_NAME=vllm-qwen3-coder-ar-${PORT}
      IMAGE=vllm-node-tf5:latest
      PORT=${PORT} HOST=${host}
      MAX_MODEL_LEN=32768 MAX_NUM_SEQS=10 KV_DTYPE_BYTES=1
      GMEM_MIN=0.55 GMEM_MAX=0.85 SAFETY_GIB=6
      EXTRA_DOCKER_ARGS="-e VLLM_ALLOW_LONG_MAX_MODEL_LEN=1 -e VLLM_MEMORY_PROFILER_ESTIMATE_CUDAGRAPHS=1 -e SAFETENSORS_FAST_GPU=1 -e VLLM_USE_FLASHINFER_MOE_FP8=1 -v ${env.REPO_CONFIG_PATH}/vllm/build/spark-vllm-docker/mods/fix-qwen3-next-autoround:/mod:ro"
      PRE_LAUNCH_CMD='cd /mod && bash run.sh'
      /app/scripts/launch-vllm-auto.sh
      --served-model-name Qwen3-Coder-Next-int4-AutoRound
      --chat-template /models/vllm/Intel/Qwen3-Coder-Next-int4-AutoRound/chat_template.jinja
      --enable-auto-tool-choice
      --tool-call-parser qwen3_coder
      --load-format fastsafetensors
      --language-model-only
      --enable-chunked-prefill
      --max-num-batched-tokens 49152
      --kv-cache-dtype fp8
      --optimization-level 3
      --performance-mode throughput
    cmdStop: "docker stop vllm-qwen3-coder-ar-${PORT}"

  # --- Instant Orchestrator - Blackwell Optimized FP8 ---
  Nemotron-3-Nano-4B-FP8:
    ttl: 0
    readyTimeout: 300
    checkEndpoint: "/health"
    cmd: >
      env
      MODEL_PATH=/models/vllm/nvidia/NVIDIA-Nemotron-3-Nano-4B-FP8
      MODEL_HOST_PATH=/models/vllm/nvidia/NVIDIA-Nemotron-3-Nano-4B-FP8
      CONTAINER_NAME=vllm-nano4b-${PORT}
      IMAGE=vllm-node:latest
      PORT=${PORT} HOST=${host}
      MAX_MODEL_LEN=8192 MAX_NUM_SEQS=10 KV_DTYPE_BYTES=1
      GMEM_MIN=0.15 GMEM_MAX=0.40 SAFETY_GIB=2
      /app/scripts/launch-vllm-auto.sh
      --served-model-name Nemotron-3-Nano-4B-FP8
      --chat-template /models/vllm/nvidia/NVIDIA-Nemotron-3-Nano-4B-FP8/chat_template.jinja
      --kv-cache-dtype fp8
      --enforce-eager
      --trust-remote-code
      --load-format fastsafetensors
      --enable-auto-tool-choice
      --tool-call-parser qwen3_coder
      --reasoning-parser nemotron_v3
    cmdStop: "docker stop vllm-nano4b-${PORT}"

  # --- spark-arena winner recipe: moe-backend cutlass, CUDA graphs, 57 tok/s ---
  Nemotron-3-Nano-30B-A3B-NVFP4:
    ttl: 0
    readyTimeout: 600
    checkEndpoint: "/health"
    cmd: >
      env
      MODEL_PATH=/models/vllm/nvidia/Nemotron-3-Nano-30B-A3B-NVFP4/hub/models--nvidia--NVIDIA-Nemotron-3-Nano-30B-A3B-NVFP4/snapshots/ab537beb128913d389306a4d0cc1a2097ac5a5af
      MODEL_HOST_PATH=/models/vllm/nvidia/Nemotron-3-Nano-30B-A3B-NVFP4/hub/models--nvidia--NVIDIA-Nemotron-3-Nano-30B-A3B-NVFP4/snapshots/ab537beb128913d389306a4d0cc1a2097ac5a5af
      CONTAINER_NAME=vllm-nemotron-${PORT}
      IMAGE=vllm-node:latest
      PORT=${PORT} HOST=${host}
      MAX_MODEL_LEN=131072 MAX_NUM_SEQS=4 KV_DTYPE_BYTES=1
      GMEM_MIN=0.40 GMEM_MAX=0.70 SAFETY_GIB=4
      EXTRA_DOCKER_ARGS='-e PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True -e OMP_NUM_THREADS=4'
      /app/scripts/launch-vllm-auto.sh
      --served-model-name Nemotron-3-Nano-30B-A3B-NVFP4
      --chat-template /models/vllm/nvidia/Nemotron-3-Nano-30B-A3B-NVFP4/hub/models--nvidia--NVIDIA-Nemotron-3-Nano-30B-A3B-NVFP4/snapshots/ab537beb128913d389306a4d0cc1a2097ac5a5af/chat_template.jinja
      --kv-cache-dtype fp8
      --moe-backend cutlass
      --load-format fastsafetensors
      --trust-remote-code
      --enable-prefix-caching
      --enable-chunked-prefill
      --max-num-batched-tokens 8192
      --enable-auto-tool-choice
      --tool-call-parser qwen3_coder
      --reasoning-parser-plugin /models/vllm/nvidia/Nemotron-3-Nano-30B-A3B-NVFP4/hub/models--nvidia--NVIDIA-Nemotron-3-Nano-30B-A3B-NVFP4/snapshots/ab537beb128913d389306a4d0cc1a2097ac5a5af/nano_v3_reasoning_parser.py
      --reasoning-parser nano_v3
    cmdStop: "docker stop vllm-nemotron-${PORT}"

  # --- NVIDIA Nemotron-3 Nano-Omni (30B MoE multimodal: text+image+audio, FP8) ---
  # Adaptive --gpu-memory-utilization via launch-vllm-auto.sh.
  # Hard ceiling 0.55 because the previous static 0.5 + multimodal preprocessor
  # (image/audio encoders, video pruning buffers) drove total RAM past 125 GiB
  # and crashed the GB10 unified pool. Tight ceiling + smaller batch profile.
  #Nemotron-3-Nano-Omni-30B-A3B-Reasoning-FP8:
  # ttl: 0
  # readyTimeout: 1200
  # checkEndpoint: "/health"
  # cmd: >
  #   env
  #   MODEL_PATH=/models/vllm/nvidia/Nemotron-3-Nano-Omni-30B-A3B-Reasoning-FP8
  #   MODEL_HOST_PATH=/models/vllm/nvidia/Nemotron-3-Nano-Omni-30B-A3B-Reasoning-FP8
  #   CONTAINER_NAME=vllm-nano-omni-${PORT}
  #   IMAGE=spark-vllm-mamba:latest
  #   PORT=${PORT} HOST=${host}
  #   MAX_MODEL_LEN=32768 MAX_NUM_SEQS=16 KV_DTYPE_BYTES=1
  #   GMEM_MIN=0.45 GMEM_MAX=0.55 SAFETY_GIB=8
  #   /app/scripts/launch-vllm-auto.sh
  #   --served-model-name Nemotron-3-Nano-Omni-30B-A3B-Reasoning-FP8
  #   --chat-template /models/vllm/nvidia/Nemotron-3-Nano-Omni-30B-A3B-Reasoning-FP8/chat_template.jinja
  #   --max-num-batched-tokens 8192
  #   --kv-cache-dtype fp8
  #   --load-format fastsafetensors
  #   --trust-remote-code
  #   --video-pruning-rate 0.5
  #   --allowed-local-media-path /
  #   --enable-prefix-caching
  #   --limit-mm-per-prompt '{"image": 2, "audio": 1}'
  #   --enable-auto-tool-choice
  #   --tool-call-parser qwen3_coder
  #   --reasoning-parser nemotron_v3
  # cmdStop: "docker stop vllm-nano-omni-${PORT}"

  # --- NVIDIA Nemotron-3 Nano-Omni (30B MoE multimodal: text+image+audio, NVFP4) ---
  # Optimized settings from Spark Arena Benchmark & NVIDIA Forums
  # Quantization: FP4, Backend: Marlin, Context: 128k
  # FIX: ttl raised to 3600 — old ttl=600 caused llama-swap to evict the model
  # mid-benchmark (warmup + 2× llama-benchy runs takes >600 s).
  # VLLM_MEMORY_PROFILER_ESTIMATE_CUDAGRAPHS=1 for accurate KV cache sizing.
  # NVFP4 multimodal — image vllm-openai has `vllm serve` as ENTRYPOINT,
  # so we use VLLM_SERVE_PREFIX="" to skip prepending it. Static gmem 0.80
  # (~97 GiB) failed mid-benchmark when prior models leaked CUDA memory;
  # adaptive launcher with GMEM_MAX=0.85 fits to actually-free VRAM.
  Nemotron-3-Nano-Omni-30B-A3B-Reasoning-NVFP4:
    ttl: 0
    readyTimeout: 1200
    checkEndpoint: "/health"
    cmd: >
      env
      MODEL_PATH=/models/vllm/nvidia/Nemotron-3-Nano-Omni-30B-A3B-Reasoning-NVFP4
      MODEL_HOST_PATH=/models/vllm/nvidia/Nemotron-3-Nano-Omni-30B-A3B-Reasoning-NVFP4
      CONTAINER_NAME=vllm-nano-omni-nvfp4-${PORT}
      IMAGE=vllm-node:latest
      PORT=${PORT} HOST=${host}
      MAX_MODEL_LEN=131072 MAX_NUM_SEQS=8 KV_DTYPE_BYTES=1
      GMEM_MIN=0.65 GMEM_MAX=0.85 SAFETY_GIB=8
      EXTRA_DOCKER_ARGS="-e VLLM_NVFP4_GEMM_BACKEND=marlin -e VLLM_USE_FLASHINFER_MOE_FP4=0 -e VLLM_ALLOW_LONG_MAX_MODEL_LEN=1 -e VLLM_MEMORY_PROFILER_ESTIMATE_CUDAGRAPHS=1 -e CUDA_MANAGED_FORCE_DEVICE_ALLOC=1 -e PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True -e OMP_NUM_THREADS=4"
      /app/scripts/launch-vllm-auto.sh
      --served-model-name Nemotron-3-Nano-Omni-30B-A3B-Reasoning-NVFP4 nemotron-3-nano-omni-nvfp4
      --chat-template /models/vllm/nvidia/Nemotron-3-Nano-Omni-30B-A3B-Reasoning-NVFP4/chat_template.jinja
      --max-num-batched-tokens 32768
      --quantization fp4
      --moe-backend marlin
      --kv-cache-dtype fp8
      --mamba-ssm-cache-dtype float32
      --enable-prefix-caching
      --reasoning-parser nemotron_v3
      --enable-auto-tool-choice
      --tool-call-parser qwen3_coder
      --video-pruning-rate 0.5
      --limit-mm-per-prompt '{"video": 1, "image": 1, "audio": 1}'
      --media-io-kwargs '{"video": {"fps": 2, "num_frames": 256}}'
      --allowed-local-media-path /
      --trust-remote-code
    cmdStop: "docker stop vllm-nano-omni-nvfp4-${PORT}"

  # --- NVIDIA Nemotron-3 Super (120B MoE - Blackwell Optimized NVFP4) ---
  # Adaptive gmem (GMEM_MAX=0.85 ceiling — large 120B model needs the headroom).
  Nemotron-3-Super-120B-A12B-NVFP4:
    ttl: 0
    readyTimeout: 1800
    checkEndpoint: "/health"
    cmd: >
      env
      MODEL_PATH=/models/vllm/nvidia/NVIDIA-Nemotron-3-Super-120B-A12B-NVFP4
      MODEL_HOST_PATH=/models/vllm/nvidia/NVIDIA-Nemotron-3-Super-120B-A12B-NVFP4
      CONTAINER_NAME=vllm-nemotron-super-${PORT}
      IMAGE=vllm-node:latest
      PORT=${PORT} HOST=${host}
      MAX_MODEL_LEN=131072 MAX_NUM_SEQS=10 KV_DTYPE_BYTES=1
      GMEM_MIN=0.65 GMEM_MAX=0.85 SAFETY_GIB=6
      EXTRA_DOCKER_ARGS="--shm-size=64g -e VLLM_FLASHINFER_ALLREDUCE_BACKEND=trtllm -e VLLM_ALLOW_LONG_MAX_MODEL_LEN=1 -e RAY_memory_monitor_refresh_ms=0"
      /app/scripts/launch-vllm-auto.sh
      --served-model-name Nemotron-3-Super-120B-A12B-NVFP4
      --chat-template /models/vllm/nvidia/NVIDIA-Nemotron-3-Super-120B-A12B-NVFP4/chat_template.jinja
      --tensor-parallel-size ${tensor_parallel}
      --kv-cache-dtype fp8
      --moe-backend cutlass
      --trust-remote-code
      --enable-prefix-caching
      --load-format fastsafetensors
      --tool-call-parser qwen3_coder
      --enable-auto-tool-choice
      --reasoning-parser nemotron_v3
      --mamba_ssm_cache_dtype float32
      --attention-backend TRITON_ATTN
      --distributed-executor-backend ray
    cmdStop: "docker stop vllm-nemotron-super-${PORT}"

  # --- spark-arena winner recipe + exp-mxfp4 CUTLASS build ---
  # Adaptive gmem (GMEM_MAX=0.85). Chat template loaded from model snapshot dir.
  GPT-OSS-120B:
    ttl: 0
    readyTimeout: 1200
    checkEndpoint: "/health"
    cmd: >
      env
      MODEL_PATH=/models/vllm/openai/GPT-OSS-120B/hub/models--openai--gpt-oss-120b/snapshots/b5c939de8f754692c1647ca79fbf85e8c1e70f8a
      MODEL_HOST_PATH=/models/vllm/openai/GPT-OSS-120B/hub/models--openai--gpt-oss-120b/snapshots/b5c939de8f754692c1647ca79fbf85e8c1e70f8a
      CONTAINER_NAME=vllm-gptoss-${PORT}
      IMAGE=vllm-node-mxfp4
      PORT=${PORT} HOST=${host}
      MAX_MODEL_LEN=65536 MAX_NUM_SEQS=10 KV_DTYPE_BYTES=1
      GMEM_MIN=0.65 GMEM_MAX=0.85 SAFETY_GIB=6
      EXTRA_DOCKER_ARGS="-e VLLM_USE_FLASHINFER_MOE_MXFP4_MXFP8=1"
      /app/scripts/launch-vllm-auto.sh
      --served-model-name GPT-OSS-120B
      --chat-template /models/vllm/openai/GPT-OSS-120B/hub/models--openai--gpt-oss-120b/snapshots/b5c939de8f754692c1647ca79fbf85e8c1e70f8a/chat_template.jinja
      --tensor-parallel-size ${tensor_parallel}
      --load-format fastsafetensors
      --quantization mxfp4
      --kv-cache-dtype fp8
      --max-num-batched-tokens 8192
      --mxfp4-backend CUTLASS
      --mxfp4-layers moe,qkv,o,lm_head
      --attention-backend FLASHINFER
      --enable-prefix-caching
      --tool-call-parser openai
      --reasoning-parser openai_gptoss
      --enable-auto-tool-choice
    cmdStop: "docker stop vllm-gptoss-${PORT}"

  # --- Works - is for fast Roleplay or Text based Stuff ---
  Mistral-Small-24B-Instruct-2501:
    ttl: 0
    readyTimeout: 900
    checkEndpoint: "/health"
    cmd: >
      docker run --rm --name vllm-mistral-small-${PORT}
      --runtime nvidia --gpus all --ipc=host --network container:llama-swap
      -e NVIDIA_DISABLE_FORWARD_COMPATIBILITY=1
      -v ${env.LLM_ROOT_PATH}/vllm:/models/vllm
      vllm-node:latest
      vllm serve /models/vllm/mistralai/Mistral-Small-24B-Instruct-2501
      --served-model-name Mistral-Small-24B-Instruct-2501
      --host ${host} --port ${PORT}
      --gpu-memory-utilization 0.42
      --max-model-len 32768
      --trust-remote-code
      --tensor-parallel-size ${tensor_parallel}
      --enforce-eager
      --enable-auto-tool-choice
      --tool-call-parser mistral
    cmdStop: "docker stop vllm-mistral-small-${PORT}"

