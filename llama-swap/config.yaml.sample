# llama-swap config.yaml
host: "0.0.0.0"
port: 8080
# Global safety: matching your local healthCheckTimeout (1 hour)
timeout: 3600
readyTimeout: 3600
healthCheckTimeout: 900
logLevel: "info" 
metricsMaxInMemory: 1000

# Global macros for cleaner model blocks
macros:
  host: "0.0.0.0"
  gpu_mem: "0.7"
  #tensor-parallel-size
  tensor_parallel: "1"

# ===================================================
# 🔀 CONCURRENT MODEL GROUPS  (S / M / L tiers)
# ===================================================
# 128GB VRAM total − ~20GB system = ~108GB available for models.
#
# Behavior:
#   swap: false     → all members in the same group stay loaded simultaneously
#   exclusive: true → evict all other groups when this group loads
#   exclusive: false → coexist with other groups (S and M can overlap)
#
# ┌──────────────────────────────────────────────────────────────────────┐
# │  Intended usage modes (pick one at a time):                          │
# │  2× S    : 2 small models simultaneously                             │
# │  1S + 1M : 1 small + 1 medium simultaneously                         │
# │  1× L    : one 120B+ model solo — evicts S and M automatically       │
# └──────────────────────────────────────────────────────────────────────┘
#
# ⚠️  VRAM NOTE: Each vLLM instance pre-allocates
#      gpu_memory_utilization × 128GB of CUDA memory.
#      Sum of all concurrent gpu_mem values must be ≤ ~0.84 to fit in 108GB.
#      Active values:
#        S tier: 0.40 (~51 GB each, 2 fit in ~102 GB)
#        M tier: 0.40 (~51 GB each, 1 M + 1 S fit in ~102 GB)
#        L tier: 0.70–0.75 (solo only — auto-evicts S and M)
# DISABLED: groups caused unexpected model swaps — when one model crashed,
# llama-swap would load another group member instead of just failing the request,
# which corrupted benchmark runs (wrong model under test).
#groups:
#
#  # S — Small / fast models: 4B–30B quantized
#  # swap:true  → load requested model, evict previous S model (models too large to coexist)
#  # exclusive:true → evict M/L groups when any S model loads
#  small-models:
#    swap: true
#    exclusive: true
#    members:
#      - Nemotron-3-Nano-4B-FP8
#      - Nemotron-3-Nano-30B-A3B-NVFP4
#      - Qwen3-Coder-Next-int4-AutoRound
#      - Qwen3.6-35B-A3B-Uncensored-HauhauCS-Aggressive
#
#  # M — Medium models: 30B FP8 / 24B BF16
#  # swap:true  → evict previous M model when loading a new one (each is 0.6–0.75 × 128GB; two cannot coexist)
#  # exclusive:true → evict S/L groups when any M model loads
#  medium-models:
#    swap: true
#    exclusive: true
#    members:
#      - Qwen3.5-35B-A3B-FP8
#      - Qwen3.6-35B-A3B-FP8
#      - Qwen3-VL-30B-A3B-Instruct-FP8
#      - Qwen3-Omni-30B-A3B-Instruct
#      - Qwen3-Coder-Next-FP8-Dynamic
#      - Mistral-Small-24B-Instruct-2501
#
#  # L — Large/solo-only models (need ≥0.7 of VRAM)
#  # swap:true  → evict the current L when a new L is requested
#  # exclusive:true → evict S and M groups when L loads (frees all VRAM)
#  large-models:
#    swap: true
#    exclusive: true
#    members:
#      - Qwen3.5-122B-A10B-int4-AutoRound
#      - Nemotron-3-Super-120B-A12B-NVFP4
#      - GPT-OSS-120B
#      - Nemotron-3-Nano-Omni-30B-A3B-Reasoning-FP8  # solo: gpu_mem 0.75 (91 GB) — recipe says 0.8 but ~28 GB system baseline forces lower
#      - Nemotron-3-Nano-Omni-30B-A3B-Reasoning-NVFP4 # solo: gpu_mem 0.80 (102 GB) — NVFP4 Optimized version

models:
# ==============================================================================
# IMAGE NAMES — TWO SEPARATE IMAGE FAMILIES
# ==============================================================================
# This config references two distinct families of Docker images:
#
# 1. STACK IMAGES  (built by build_and_push.sh, pulled via docker-compose.yml)
#    <registry>/<namespace>/llama-cpp-spark:latest
#    <registry>/<namespace>/vllm-spark:latest   ← persistent, always-on service
#    <registry>/<namespace>/llama-swap-spark:latest
#    <registry>/<namespace>/ollama-spark:latest
#    <registry>/<namespace>/litellm-spark:latest
#    These run as long-lived Docker Compose services.
#
# 2. EPHEMERAL vLLM IMAGES  (built from vllm/build/spark-vllm-docker submodule)
#    vllm-node:latest                             ← standard vLLM (most models)
#    vllm-node-tf5:latest                         ← transformers v5 (Mamba/hybrid)
#    vllm-node-mxfp4:latest                       ← CUTLASS MXFP4 (GPT-OSS-120B)
#    vllm/vllm-openai:v0.20.0-aarch64-cu130-*    ← upstream NVIDIA image (Docker Hub)
#    llama-swap spawns these on demand via `docker run` and evicts them when idle.
#
# To build the ephemeral vLLM images (one-time, ~20–60 min):
#   git submodule update --init --recursive
#   cd vllm/build/spark-vllm-docker
#   ./build-and-copy.sh           # → vllm-node:latest
#   ./build-and-copy.sh --tf5     # → vllm-node-tf5:latest
#   ./build-and-copy.sh --exp-mxfp4  # → vllm-node-mxfp4:latest
# ==============================================================================

# --- llama.cpp GGUF Model ---
# Best for specific GGUF quants not handled well by vLLM
# These use the paths from your models.ini but are managed by llama-swap
# --- llama.cpp GGUF Models (Dockerized) - Unified Memory Optimized ---

  TheDrummer_GLM-Steam-106B-A12B-v1-Q4_K_M-GGUF:
   ttl: 0
   readyTimeout: 1200
   checkEndpoint: "/health" 
   cmd: >
     docker run --rm --name llamacpp-glm-${PORT}
     --runtime nvidia --gpus all --ipc host --network container:llama-swap
     --ulimit memlock=-1 --ulimit stack=67108864
     --security-opt seccomp=unconfined
     -e GGML_CUDA_ENABLE_UNIFIED_MEMORY=1
     -v ${env.LLM_ROOT_PATH}/ollama:/models/ollama
     ${env.REGISTRY}/${env.IMAGE_NAMESPACE}/llama-cpp-spark:latest
     -m /models/ollama/TheDrummer/GLM-Steam-106B-A12B-v1-GGUF/GLM-Steam-106B-A12B-v1b-Q4_K_M-00001-of-00002.gguf
     --port ${PORT} --host ${host}
     --ctx-size 8192 --n-gpu-layers 99 --parallel 4 --no-mmap
   cmdStop: "docker stop llamacpp-glm-${PORT}"

#  TheDrummer_GLM-Steam-106B-A12B-v1-Q4_K_M:
#    endpoint: "http://127.0.0.1:18080"
    # No cmd needed since the server is already running
    # llama-swap will route requests here when this model name is called

  Nemotron-3-Nano-4B-Q4_K_M-GGUF:
   ttl: 0
   readyTimeout: 300
   checkEndpoint: "/health" 
   cmd: >
     docker run --rm --name llamacpp-nano-${PORT}
     --runtime nvidia --gpus all --ipc host --network container:llama-swap
     -e GGML_CUDA_ENABLE_UNIFIED_MEMORY=1
     -v ${env.LLM_ROOT_PATH}/gguf:/models/gguf
     ${env.REGISTRY}/${env.IMAGE_NAMESPACE}/llama-cpp-spark:latest
     -m /models/gguf/nvidia/NVIDIA-Nemotron-3-Nano-4B-GGUF/NVIDIA-Nemotron3-Nano-4B-Q4_K_M.gguf
     --port ${PORT} --host ${host}
     --ctx-size 8192 --n-gpu-layers 99 --parallel 1 --no-mmap
   cmdStop: "docker stop llamacpp-nano-${PORT}"

  Qwen3.6-35B-A3B-Uncensored-HauhauCS-Aggressive:
    ttl: 0
    readyTimeout: 300
    checkEndpoint: "/health"
    cmd: >
      docker run --rm --name llamacpp-qwen-${PORT}
      --runtime nvidia --gpus all --ipc host --network container:llama-swap
      --ulimit memlock=-1 --ulimit stack=67108864
      --security-opt seccomp=unconfined
      -e GGML_CUDA_ENABLE_UNIFIED_MEMORY=1
      -v ${env.LLM_ROOT_PATH}/vllm:/models/vllm
      ${env.REGISTRY}/${env.IMAGE_NAMESPACE}/llama-cpp-spark:latest
      -m /models/vllm/HauhauCS/Qwen3.6-35B-A3B-Uncensored-HauhauCS-Aggressive/Qwen3.6-35B-A3B-Uncensored-HauhauCS-Aggressive-IQ2_M.gguf
      --port ${PORT} --host ${host}
      --ctx-size 65536 --n-gpu-layers 99 --parallel 4 --no-mmap
      --jinja
    cmdStop: "docker stop llamacpp-qwen-${PORT}"

  # --- Qwen3.6-27B Uncensored Heretic v2 (NVFP4-MLP GGUF, llama.cpp) ---
  # Abliterated via Heretic MPOA v2 — all 15 MTP tensors preserved.
  # MMLU: 85.67% (vs 86.65% original — minimal quality loss).
  # 28 GiB on disk (BF16 attention + NVFP4 MLP-only). Fits comfortably in 128 GiB.
  # --no-mmap omitted: forced the full file into heap upfront, causing RAM spikes.
  # --parallel 2 (not 4): halves KV cache (~17 GiB → ~8.5 GiB at 65K ctx).
  # ⚠️  Update -m path to the exact GGUF filename after download.
  Qwen3.6-27B-uncensored-heretic-NVFP4:
    ttl: 0
    readyTimeout: 300
    checkEndpoint: "/health"
    cmd: >
      docker run --rm --name llamacpp-qwen27b-${PORT}
      --runtime nvidia --gpus all --ipc host --network container:llama-swap
      --ulimit memlock=-1 --ulimit stack=67108864
      --security-opt seccomp=unconfined
      -v ${env.LLM_ROOT_PATH}/ollama:/models/ollama
      ${env.REGISTRY}/${env.IMAGE_NAMESPACE}/llama-cpp-spark:latest
      -m /models/ollama/llmfan46/Qwen3.6-27B-uncensored-heretic-v2-Native-MTP-Preserved-NVFP4-GGUF/Qwen3.6-27B-uncensored-heretic-v2-Native-MTP-Preserved-NVFP4-MLP-Only.gguf
      --alias Qwen3.6-27B-uncensored-heretic-NVFP4
      --port ${PORT} --host ${host}
      --ctx-size 65536 --n-gpu-layers 99 --parallel 2
      --jinja
      --reasoning-budget 1024
    cmdStop: "docker stop llamacpp-qwen27b-${PORT}"

  Qwen3.5-27B-Uncensored-HauhauCS-Aggressive-BF16:
   ttl: 0
   readyTimeout: 300
   checkEndpoint: "/health" 
   cmd: >
     docker run --rm --name llamacpp-qwen-${PORT}
     --runtime nvidia --gpus all --ipc host --network container:llama-swap
     --ulimit memlock=-1 --ulimit stack=67108864
     --security-opt seccomp=unconfined
     -e GGML_CUDA_ENABLE_UNIFIED_MEMORY=1
     -v ${env.LLM_ROOT_PATH}/ollama:/models/ollama
     ${env.REGISTRY}/${env.IMAGE_NAMESPACE}/llama-cpp-spark:latest
     -m /models/ollama/HauhauCS/Qwen3.5-27B-Uncensored-HauhauCS-Aggressive/Qwen3.5-27B-Uncensored-HauhauCS-Aggressive-BF16.gguf
     --port ${PORT} --host ${host}
     --ctx-size 16384 --n-gpu-layers 99 --parallel 4 --no-mmap
   cmdStop: "docker stop llamacpp-qwen-${PORT}"

#  dolphin-mistral-24b:
#    ttl: 0
#    readyTimeout: 300
#    checkEndpoint: "/health" 
#    cmd: >
#      docker run --rm --name llamacpp-dolphin-${PORT}
#      --runtime nvidia --gpus all --ipc host --network container:llama-swap
#      -e GGML_CUDA_ENABLE_UNIFIED_MEMORY=1
