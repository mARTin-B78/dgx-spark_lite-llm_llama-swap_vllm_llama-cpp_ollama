  Qwen3.5-35B-A3B-Uncensored-HauhauCS-Aggressive-Q4_K_M-GGUF:
    ttl: 600
    readyTimeout: 300
    checkEndpoint: "/health" 
    cmd: >
      docker run --rm --name llamacpp-qwen-${PORT}
      --runtime nvidia --gpus all --ipc host --network container:llama-swap
      --ulimit memlock=-1 --ulimit stack=67108864
      --security-opt seccomp=unconfined
      -e GGML_CUDA_ENABLE_UNIFIED_MEMORY=1
      -v <LLM_ROOT_PATH>/ollama:/models/ollama
      ghcr.io/<YOUR_GITHUB_USER>/llama-cpp-spark:latest
      -m /models/ollama/Alibaba/Qwen3.5-35B-A3B-Uncensored-HauhauCS-Aggressive/Qwen3.5-35B-A3B-Uncensored-HauhauCS-Aggressive-Q4_K_M.gguf
      --port ${PORT} --host ${host}
      --ctx-size 16384 --n-gpu-layers 99 --parallel 4 --no-mmap
      --chat-template-file /models/ollama/Alibaba/Qwen3.5-35B-A3B-Uncensored-HauhauCS-Aggressive/custom_chat_template.jinja
    cmdStop: \"docker stop llamacpp-qwen-${PORT}\"


