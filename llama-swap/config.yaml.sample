# --- Persistent llama.cpp Models ---
  # Note: These point to your existing server on port 18080
  

#  NVIDIA-Nemotron3-Nano-4B-Q4_K_M:
#    endpoint: "http://127.0.0.1:18080"
#
#  Qwen3.5-35B-A3B-Uncensored-HauhauCS-Aggressive:
#    endpoint: "http://127.0.0.1:18080"


  # --- VLLM MODELS ---
  # --- Optimized: MTP-2 + FLASHINFER + chunked prefill + enhanced template ---
  # Adaptive gmem via launch-vllm-auto.sh.
  # Set GMEM_OVERRIDE=0.40 (or any number 0..1) to pin static. Unset/"adaptive"
  # for dynamic. SYSTEM_RAM_CEILING_GIB defaults to 117.81 (= 126.5 GB).
  Qwen3.5-35B-A3B-FP8:
    ttl: 600
    checkEndpoint: "/health"
    cmd: >
      env
      MODEL_PATH=/models/vllm/Alibaba/Qwen3.5-35B-A3B-FP8
      MODEL_HOST_PATH=/models/vllm/Alibaba/Qwen3.5-35B-A3B-FP8
      CONTAINER_NAME=vllm-qwen3.5-35b-${PORT}
      IMAGE=vllm-node:Version_1
      PORT=${PORT} HOST=${host}
      MAX_MODEL_LEN=131072 MAX_NUM_SEQS=16 KV_DTYPE_BYTES=1
      GMEM_MIN=0.40 GMEM_MAX=0.75 SAFETY_GIB=4
      EXTRA_DOCKER_ARGS='-e VLLM_ENABLE_CUDAGRAPH_GC=1 -e VLLM_USE_FLASHINFER_SAMPLER=1 -v <REPO_CONFIG_PATH>/vllm/build/spark-vllm-docker/mods/fix-qwen3.5-chat-template/qwen3.5-enhanced.jinja:/models/vllm/custom_template.jinja:ro'
      /app/scripts/launch-vllm-auto.sh
      --served-model-name Qwen3.5-35B-A3B-FP8
      --max-num-batched-tokens 4096
      --kv-cache-dtype fp8
      --load-format fastsafetensors
      --attention-backend FLASHINFER
      --enable-prefix-caching
      --enable-chunked-prefill
      --speculative-config '{"method":"mtp","num_speculative_tokens":2}'
      --chat-template /models/vllm/custom_template.jinja
      --tensor-parallel-size 1
      --enable-auto-tool-choice
      --tool-call-parser qwen3_xml
      --reasoning-parser qwen3
    cmdStop: "docker stop vllm-qwen3.5-35b-${PORT}"

  # --- Optimized: fp8 KV cache + prefix caching + enhanced template ---
  # NOTE: For 51 tok/s with MTP, needs albond/DGX_Spark patches + hybrid INT4+FP8 checkpoint
  # Mamba hybrid arch requires max-num-batched-tokens >= block_size (4176 in align mode)
  Qwen3.5-122B-A10B-int4-AutoRound:
    ttl: 3600
    readyTimeout: 1800
    checkEndpoint: "/health"
    cmd: >
      env
      MODEL_PATH=/models/vllm/Alibaba/Qwen3.5-122B-A10B-int4-AutoRound
      MODEL_HOST_PATH=/models/vllm/Alibaba/Qwen3.5-122B-A10B-int4-AutoRound
      CONTAINER_NAME=vllm-qwen3.5-122b-${PORT}
      IMAGE=vllm-node-tf5:latest
      PORT=${PORT} HOST=${host}
      MAX_MODEL_LEN=40960 MAX_NUM_SEQS=10 KV_DTYPE_BYTES=1
      GMEM_MIN=0.78 GMEM_MAX=0.85 SAFETY_GIB=4
      EXTRA_DOCKER_ARGS='-v <REPO_CONFIG_PATH>/vllm/build/spark-vllm-docker/mods/fix-qwen3.5-chat-template/qwen3.5-enhanced.jinja:/models/vllm/custom_template.jinja:ro'
      /app/scripts/launch-vllm-auto.sh
      --served-model-name Qwen3.5-122B-A10B-int4-AutoRound
      --tensor-parallel-size ${tensor_parallel}
      --max-num-batched-tokens 8192
      --trust-remote-code
      --enforce-eager
      --kv-cache-dtype fp8
      --enable-prefix-caching
      --chat-template /models/vllm/custom_template.jinja
      --enable-auto-tool-choice
      --tool-call-parser qwen3_xml
      --reasoning-parser qwen3
    cmdStop: "docker stop vllm-qwen3.5-122b-${PORT}"

  # --- Works - is for Visual Stuff with Pictures ---
  Qwen3-VL-30B-A3B-Instruct-FP8:
    ttl: 600
    checkEndpoint: "/health"
    cmd: >
      env
      MODEL_PATH=/models/vllm/Alibaba/Qwen3-VL-30B-A3B-Instruct-FP8
      MODEL_HOST_PATH=/models/vllm/Alibaba/Qwen3-VL-30B-A3B-Instruct-FP8
      CONTAINER_NAME=vllm-qwen3-vl-${PORT}
      IMAGE=vllm-node:Version_1
      PORT=${PORT} HOST=${host}
      MAX_MODEL_LEN=32768 MAX_NUM_SEQS=10 KV_DTYPE_BYTES=1
      GMEM_MIN=0.40 GMEM_MAX=0.65 SAFETY_GIB=4
      /app/scripts/launch-vllm-auto.sh
      --served-model-name Qwen3-VL-30B-A3B-Instruct-FP8
      --trust-remote-code
      --limit-mm-per-prompt '{"image": 2}'
      --kv-cache-dtype fp8
      --load-format fastsafetensors
      --enable-prefix-caching
      --tensor-parallel-size 1
      --enable-auto-tool-choice
      --tool-call-parser qwen3_coder
    cmdStop: "docker stop vllm-qwen3-vl-${PORT}"

  # --- Works - is for Pictures, Sound, Text ---
  # Qwen3-Omni 30B BF16 multimodal — weights ~60 GiB, KV ~6 GiB at 32K.
  # Static --gpu-memory-utilization 0.40 (~49 GiB) was below weights → KV ValueError.
  # Switched to launch-vllm-auto.sh: GMEM_MIN=0.60, GMEM_MAX=0.75.
  Qwen3-Omni-30B-A3B-Instruct:
    ttl: 600
    readyTimeout: 600
    checkEndpoint: "/health"
    cmd: >
      env
      MODEL_PATH=/models/vllm/Alibaba/Qwen3-Omni-30B-A3B-Instruct
      MODEL_HOST_PATH=/models/vllm/Alibaba/Qwen3-Omni-30B-A3B-Instruct
      CONTAINER_NAME=vllm-qwen3-omni-${PORT}
      IMAGE=vllm-node:Version_1
      PORT=${PORT} HOST=${host}
      MAX_MODEL_LEN=32768 MAX_NUM_SEQS=10 KV_DTYPE_BYTES=2
      GMEM_MIN=0.60 GMEM_MAX=0.75 SAFETY_GIB=6
      /app/scripts/launch-vllm-auto.sh
      --served-model-name Qwen3-Omni-30B-A3B-Instruct
      --trust-remote-code
      --limit-mm-per-prompt '{"image": 2, "audio": 2}'
      --load-format fastsafetensors
      --enable-prefix-caching
      --tensor-parallel-size ${tensor_parallel}
      --enable-auto-tool-choice
      --tool-call-parser hermes
     # USE ONLY THIS PARSER FOR OMNI:
     # REMOVE --reasoning-parser qwen3
    cmdStop: "docker stop vllm-qwen3-omni-${PORT}"


  # --- is for Coding (Qwen3-Next ~480B-A22B, FP8 Dynamic) ---
  # Weights ≈ 77.8 GiB. Uses launch-vllm-auto.sh + PRE_LAUNCH_CMD to apply
  # the AutoRound mod patch before vllm starts. Auto-fits gmem to free VRAM.
  Qwen3-Coder-Next-FP8-Dynamic:
    ttl: 3600
    readyTimeout: 1200
    checkEndpoint: "/health"
    cmd: >
      env
      MODEL_PATH=/models/vllm/Alibaba/Qwen3-Coder-Next-FP8-Dynamic
      MODEL_HOST_PATH=/models/vllm/Alibaba/Qwen3-Coder-Next-FP8-Dynamic
      CONTAINER_NAME=vllm-qwen3-coder-${PORT}
      IMAGE=vllm-node-tf5:latest
      PORT=${PORT} HOST=${host}
      MAX_MODEL_LEN=32768 MAX_NUM_SEQS=10 KV_DTYPE_BYTES=1
      GMEM_MIN=0.80 GMEM_MAX=0.92 SAFETY_GIB=6
      EXTRA_DOCKER_ARGS='-e VLLM_MEMORY_PROFILER_ESTIMATE_CUDAGRAPHS=1 -v <REPO_CONFIG_PATH>/vllm/build/spark-vllm-docker/mods/fix-qwen3-next-autoround:/mod:ro'
      PRE_LAUNCH_CMD='cd /mod && bash run.sh'
      /app/scripts/launch-vllm-auto.sh
      --served-model-name Qwen3-Coder-Next-FP8-Dynamic
      --kv-cache-dtype fp8
      --load-format fastsafetensors
      --attention-backend flashinfer
      --enable-prefix-caching
      --enable-auto-tool-choice
      --tool-call-parser qwen3_coder
     # NOTE: no --reasoning-parser (Coder-Next doesn't expose <think> in standard mode)
    cmdStop: "docker stop vllm-qwen3-coder-${PORT}"

  # --- Optimized: 1M context, INT4 AutoRound, spark-arena v2 recipe ---
  # Same launcher pattern as the FP8-Dynamic block — adaptive gmem + mod patch.
  Qwen3-Coder-Next-int4-AutoRound:
    ttl: 3600
    readyTimeout: 1200
    checkEndpoint: "/health"
    cmd: >
      env
      MODEL_PATH=/models/vllm/Alibaba/Qwen3-Coder-Next-int4-AutoRound
      MODEL_HOST_PATH=/models/vllm/Alibaba/Qwen3-Coder-Next-int4-AutoRound
      CONTAINER_NAME=vllm-qwen3-coder-ar-${PORT}
      IMAGE=vllm-node-tf5:latest
      PORT=${PORT} HOST=${host}
      MAX_MODEL_LEN=32768 MAX_NUM_SEQS=384 KV_DTYPE_BYTES=1
      GMEM_MIN=0.55 GMEM_MAX=0.85 SAFETY_GIB=6
      EXTRA_DOCKER_ARGS='-e VLLM_ALLOW_LONG_MAX_MODEL_LEN=1 -e VLLM_MEMORY_PROFILER_ESTIMATE_CUDAGRAPHS=1 -e SAFETENSORS_FAST_GPU=1 -e VLLM_USE_FLASHINFER_MOE_FP8=1 -v <REPO_CONFIG_PATH>/vllm/build/spark-vllm-docker/mods/fix-qwen3-next-autoround:/mod:ro'
      PRE_LAUNCH_CMD='cd /mod && bash run.sh'
      /app/scripts/launch-vllm-auto.sh
      --served-model-name Qwen3-Coder-Next-int4-AutoRound
      --enable-auto-tool-choice
      --tool-call-parser qwen3_coder
      --load-format fastsafetensors
      --language-model-only
      --enable-chunked-prefill
      --max-num-batched-tokens 49152
      --kv-cache-dtype fp8
      --optimization-level 3
      --performance-mode throughput
     # REMOVE --reasoning-parser qwen3
    cmdStop: "docker stop vllm-qwen3-coder-ar-${PORT}"

# --- Instant Orchestrator - Blackwell Optimized FP8 ---
  Nemotron-3-Nano-4B-FP8:
    ttl: 300
    readyTimeout: 300
    checkEndpoint: "/health"
    cmd: >
      env
      MODEL_PATH=/models/vllm/Nvidia/Nemotron-3-Nano-4B-FP8
      MODEL_HOST_PATH=/models/vllm/Nvidia/Nemotron-3-Nano-4B-FP8
      CONTAINER_NAME=vllm-nano4b-${PORT}
      IMAGE=spark-vllm:Version_1
      PORT=${PORT} HOST=${host}
      MAX_MODEL_LEN=8192 MAX_NUM_SEQS=10 KV_DTYPE_BYTES=1
      GMEM_MIN=0.10 GMEM_MAX=0.40 SAFETY_GIB=2
      /app/scripts/launch-vllm-auto.sh
      --served-model-name Nemotron-3-Nano-4B-FP8
      --kv-cache-dtype fp8
      --enforce-eager
      --trust-remote-code
      --load-format fastsafetensors
      --enable-prefix-caching
      --tool-call-parser qwen3_coder
      --reasoning-parser nemotron_v3
    cmdStop: "docker stop vllm-nano4b-${PORT}"

  # --- Works - is for Speed ---
  Nemotron-3-Nano-30B-A3B-NVFP4:
    ttl: 300
    readyTimeout: 600
    checkEndpoint: "/health"
    cmd: >
      env
      MODEL_PATH=/models/vllm/Nvidia/Nemotron-3-Nano-30B-A3B-NVFP4/hub/models--nvidia--NVIDIA-Nemotron-3-Nano-30B-A3B-NVFP4/snapshots/ab537beb128913d389306a4d0cc1a2097ac5a5af
      MODEL_HOST_PATH=/models/vllm/Nvidia/Nemotron-3-Nano-30B-A3B-NVFP4/hub/models--nvidia--NVIDIA-Nemotron-3-Nano-30B-A3B-NVFP4/snapshots/ab537beb128913d389306a4d0cc1a2097ac5a5af
      CONTAINER_NAME=vllm-nemotron-${PORT}
      IMAGE=vllm-node:Version_1
      PORT=${PORT} HOST=${host}
      MAX_MODEL_LEN=131072 MAX_NUM_SEQS=10 KV_DTYPE_BYTES=1
      GMEM_MIN=0.40 GMEM_MAX=0.70 SAFETY_GIB=4
      EXTRA_DOCKER_ARGS='-e VLLM_USE_FLASHINFER_MOE_FP4=1 -e VLLM_FLASHINFER_MOE_BACKEND=throughput'
      /app/scripts/launch-vllm-auto.sh
      --served-model-name Nemotron-3-Nano-30B-A3B-NVFP4
      --kv-cache-dtype fp8
      --enforce-eager
      --trust-remote-code
      --quantization modelopt_fp4
      --enable-auto-tool-choice
      --tool-call-parser qwen3_coder
      --reasoning-parser-plugin /models/vllm/Nvidia/Nemotron-3-Nano-30B-A3B-NVFP4/nano_v3_reasoning_parser.py
      --reasoning-parser nano_v3
    cmdStop: "docker stop vllm-nemotron-${PORT}"

# --- NVIDIA Nemotron-3 Nano-Omni (30B MoE multimodal: text+image+audio+video, NVFP4) ---
# Image vllm/vllm-openai has `vllm serve` as ENTRYPOINT, so VLLM_SERVE_PREFIX=""
# is set to skip prepending it. Adaptive gmem (GMEM_MAX=0.85) handles the
# CUDA-memory-pressure failure mode seen mid-benchmark with static 0.80.
  Nemotron-3-Nano-Omni-30B-A3B-Reasoning-NVFP4:
    ttl: 3600
    readyTimeout: 1200
    checkEndpoint: "/health"
    cmd: >
      env
      MODEL_PATH=/models/vllm/Nvidia/Nemotron-3-Nano-Omni-30B-A3B-Reasoning-NVFP4
      MODEL_HOST_PATH=/models/vllm/Nvidia/Nemotron-3-Nano-Omni-30B-A3B-Reasoning-NVFP4
      CONTAINER_NAME=vllm-nano-omni-nvfp4-${PORT}
      IMAGE=vllm/vllm-openai:v0.20.0-aarch64-cu130-ubuntu2404
      PORT=${PORT} HOST=${host}
      MAX_MODEL_LEN=131072 MAX_NUM_SEQS=8 KV_DTYPE_BYTES=1
      GMEM_MIN=0.65 GMEM_MAX=0.85 SAFETY_GIB=8
      VLLM_SERVE_PREFIX=""
      EXTRA_DOCKER_ARGS='-e VLLM_NVFP4_GEMM_BACKEND=marlin -e VLLM_USE_FLASHINFER_MOE_FP4=0 -e VLLM_ALLOW_LONG_MAX_MODEL_LEN=1 -e VLLM_MEMORY_PROFILER_ESTIMATE_CUDAGRAPHS=1 -e CUDA_MANAGED_FORCE_DEVICE_ALLOC=1 -e PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True -e OMP_NUM_THREADS=4'
      /app/scripts/launch-vllm-auto.sh
      --served-model-name Nemotron-3-Nano-Omni-30B-A3B-Reasoning-NVFP4 nemotron-3-nano-omni-nvfp4
      --chat-template /models/vllm/Nvidia/Nemotron-3-Nano-Omni-30B-A3B-Reasoning-NVFP4/chat_template.jinja
      --max-num-batched-tokens 32768
      --quantization fp4
      --moe-backend marlin
      --kv-cache-dtype fp8
      --mamba-ssm-cache-dtype float32
      --enable-prefix-caching
      --reasoning-parser nemotron_v3
      --enable-auto-tool-choice
      --tool-call-parser qwen3_coder
      --video-pruning-rate 0.5
      --limit-mm-per-prompt '{"video": 1, "image": 1, "audio": 1}'
      --media-io-kwargs '{"video": {"fps": 2, "num_frames": 256}}'
      --allowed-local-media-path /
      --trust-remote-code
    cmdStop: "docker stop vllm-nano-omni-nvfp4-${PORT}"

# --- NVIDIA Nemotron-3 Super (120B MoE - Blackwell Optimized NVFP4) ---
  Nemotron-3-Super-120B-A12B-NVFP4:
    ttl: 3600
    readyTimeout: 1800
    checkEndpoint: "/health"
    cmd: >
      env
      MODEL_PATH=/models/vllm/Nvidia/NVIDIA-Nemotron-3-Super-120B-A12B-NVFP4
      MODEL_HOST_PATH=/models/vllm/Nvidia/NVIDIA-Nemotron-3-Super-120B-A12B-NVFP4
      CONTAINER_NAME=vllm-nemotron-super-${PORT}
      IMAGE=spark-vllm:Version_1
      PORT=${PORT} HOST=${host}
      MAX_MODEL_LEN=65536 MAX_NUM_SEQS=10 KV_DTYPE_BYTES=1
      GMEM_MIN=0.65 GMEM_MAX=0.85 SAFETY_GIB=6
      EXTRA_DOCKER_ARGS='--shm-size=64g -e VLLM_FLASHINFER_ALLREDUCE_BACKEND=trtllm -e VLLM_ALLOW_LONG_MAX_MODEL_LEN=1 -e RAY_memory_monitor_refresh_ms=0'
      /app/scripts/launch-vllm-auto.sh
      --served-model-name Nemotron-3-Super-120B-A12B-NVFP4
      --tensor-parallel-size ${tensor_parallel}
      --kv-cache-dtype fp8
      --moe-backend cutlass
      --trust-remote-code
      --enable-prefix-caching
      --load-format fastsafetensors
      --tool-call-parser qwen3_coder
      --enable-auto-tool-choice
      --reasoning-parser nemotron_v3
      --mamba_ssm_cache_dtype float32
      --attention-backend TRITON_ATTN
      --distributed-executor-backend ray
    cmdStop: "docker stop vllm-nemotron-super-${PORT}"
 #    --max-model-len 262144

  # --- Works - is for Text based stuff and Coding ---
  GPT-OSS-120B:
    ttl: 3600
    readyTimeout: 1200
    checkEndpoint: "/health"
    cmd: >
      env
      MODEL_PATH=/models/vllm/OpenAI/GPT-OSS-120B/hub/models--openai--gpt-oss-120b/snapshots/b5c939de8f754692c1647ca79fbf85e8c1e70f8a
      MODEL_HOST_PATH=/models/vllm/OpenAI/GPT-OSS-120B/hub/models--openai--gpt-oss-120b/snapshots/b5c939de8f754692c1647ca79fbf85e8c1e70f8a
      CONTAINER_NAME=vllm-gptoss-${PORT}
      IMAGE=vllm-node-mxfp4
      PORT=${PORT} HOST=${host}
      MAX_MODEL_LEN=65536 MAX_NUM_SEQS=10 KV_DTYPE_BYTES=1
      GMEM_MIN=0.65 GMEM_MAX=0.85 SAFETY_GIB=6
      EXTRA_DOCKER_ARGS='-e VLLM_USE_FLASHINFER_MOE_MXFP4_MXFP8=1'
      /app/scripts/launch-vllm-auto.sh
      --served-model-name GPT-OSS-120B
      --tensor-parallel-size ${tensor_parallel}
      --load-format fastsafetensors
      --quantization mxfp4
      --kv-cache-dtype fp8
      --max-num-batched-tokens 8192
      --enable-prefix-caching
      --tool-call-parser openai
      --reasoning-parser openai_gptoss
      --enable-auto-tool-choice
    cmdStop: "docker stop vllm-gptoss-${PORT}"

  # --- Works - is for fast Roleplay or Text based Stuff ---
  Mistral-Small-24B-Instruct-2501:
    ttl: 600
    checkEndpoint: "/health"
    cmd: >
      env
      MODEL_PATH=/models/vllm/Mistral/Mistral-Small-24B-Instruct-2501
      MODEL_HOST_PATH=/models/vllm/Mistral/Mistral-Small-24B-Instruct-2501
      CONTAINER_NAME=vllm-mistral-small-${PORT}
      IMAGE=vllm-node:Version_1
      PORT=${PORT} HOST=${host}
      MAX_MODEL_LEN=32768 MAX_NUM_SEQS=10 KV_DTYPE_BYTES=2
      GMEM_MIN=0.40 GMEM_MAX=0.65 SAFETY_GIB=4
      /app/scripts/launch-vllm-auto.sh
      --served-model-name Mistral-Small-24B-Instruct-2501
      --trust-remote-code
      --tensor-parallel-size ${tensor_parallel}
      --enforce-eager
      --enable-auto-tool-choice
      --tool-call-parser mistral
    cmdStop: "docker stop vllm-mistral-small-${PORT}"

