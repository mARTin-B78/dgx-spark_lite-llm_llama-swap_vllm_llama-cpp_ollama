# --- Persistent llama.cpp Models ---
  # Note: These point to your existing server on port 18080
  

#  NVIDIA-Nemotron3-Nano-4B-Q4_K_M:
#    endpoint: "http://127.0.0.1:18080"
#
#  Qwen3.5-35B-A3B-Uncensored-HauhauCS-Aggressive:
#    endpoint: "http://127.0.0.1:18080"


  # --- VLLM MODELS ---
  # --- Optimized: MTP-2 + FLASHINFER + chunked prefill + enhanced template ---
  Qwen3.5-35B-A3B-FP8:
    ttl: 600
    cmd: >
      docker run --rm --name vllm-qwen3.5-35b-${PORT}
      --runtime nvidia --gpus all --ipc=host --network container:llama-swap
      -e NVIDIA_DISABLE_FORWARD_COMPATIBILITY=1
      -e VLLM_MARLIN_USE_ATOMIC_ADD=1
      -e VLLM_ENABLE_CUDAGRAPH_GC=1
      -e VLLM_USE_FLASHINFER_SAMPLER=1
      -v <LLM_ROOT_PATH>/vllm:/models/vllm
      -v <REPO_CONFIG_PATH>/vllm/build/spark-vllm-docker/mods/fix-qwen3.5-chat-template/qwen3.5-enhanced.jinja:/models/vllm/custom_template.jinja:ro
      vllm-node:Version_1
      vllm serve /models/vllm/Alibaba/Qwen3.5-35B-A3B-FP8
      --served-model-name Qwen3.5-35B-A3B-FP8
      --host ${host} --port ${PORT}
      --gpu-memory-utilization 0.7
      --max-model-len 131072
      --max-num-seqs 16
      --max-num-batched-tokens 4096
      --kv-cache-dtype fp8
      --load-format fastsafetensors
      --attention-backend FLASHINFER
      --enable-prefix-caching
      --enable-chunked-prefill
      --speculative-config '{"method":"mtp","num_speculative_tokens":2}'
      --chat-template /models/vllm/custom_template.jinja
      --tensor-parallel-size 1
      --enable-auto-tool-choice
      --tool-call-parser qwen3_xml
      --reasoning-parser qwen3
    cmdStop: "docker stop vllm-qwen3.5-35b-${PORT}"

  # --- Optimized: fp8 KV cache + prefix caching + enhanced template ---
  # NOTE: For 51 tok/s with MTP, needs albond/DGX_Spark patches + hybrid INT4+FP8 checkpoint
  # Mamba hybrid arch requires max-num-batched-tokens >= block_size (4176 in align mode)
  Qwen3.5-122B-A10B-int4-AutoRound:
    ttl: 3600
    readyTimeout: 1800
    cmd: >
      docker run --rm --name vllm-qwen3.5-122b-${PORT}
      --runtime nvidia --gpus all --ipc=host --network container:llama-swap
      -e NVIDIA_DISABLE_FORWARD_COMPATIBILITY=1
      -e VLLM_MARLIN_USE_ATOMIC_ADD=1
      -v <LLM_ROOT_PATH>/vllm:/models/vllm
      -v <REPO_CONFIG_PATH>/vllm/build/spark-vllm-docker/mods/fix-qwen3.5-chat-template/qwen3.5-enhanced.jinja:/models/vllm/custom_template.jinja:ro
      vllm-node-tf5:latest
      vllm serve /models/vllm/Alibaba/Qwen3.5-122B-A10B-int4-AutoRound
      --served-model-name Qwen3.5-122B-A10B-int4-AutoRound
      --host ${host} --port ${PORT}
      --gpu-memory-utilization 0.75
      --tensor-parallel-size ${tensor_parallel} 
      --max-model-len 40960
      --max-num-batched-tokens 8192
      --trust-remote-code
      --enforce-eager
      --kv-cache-dtype fp8
      --enable-prefix-caching
      --chat-template /models/vllm/custom_template.jinja
      --enable-auto-tool-choice
      --tool-call-parser qwen3_xml
      --reasoning-parser qwen3
    cmdStop: "docker stop vllm-qwen3.5-122b-${PORT}"

  # --- Works - is for Visual Stuff with Pictures ---
  Qwen3-VL-30B-A3B-Instruct-FP8:
    ttl: 600 
    cmd: >
      docker run --rm --name vllm-qwen3-vl-${PORT} 
      --runtime nvidia --gpus all --ipc=host --network container:llama-swap
      -e NVIDIA_DISABLE_FORWARD_COMPATIBILITY=1
      -v <LLM_ROOT_PATH>/vllm:/models/vllm 
      vllm-node:Version_1 
      python3 -m vllm.entrypoints.openai.api_server
      --model /models/vllm/Alibaba/Qwen3-VL-30B-A3B-Instruct-FP8
      --served-model-name Qwen3-VL-30B-A3B-Instruct-FP8
      --host ${host} --port ${PORT}
      --max-model-len 32768
      --gpu-memory-utilization 0.60
      --trust-remote-code
      --limit-mm-per-prompt '{"image": 2}'
      --kv-cache-dtype fp8
      --load-format fastsafetensors
      --enable-prefix-caching
      --tensor-parallel-size 1
      --enable-auto-tool-choice
      --tool-call-parser qwen3_coder
    cmdStop: "docker stop vllm-qwen3-vl-${PORT}"

  # --- Works - is for Pictures, Sound, Text ---
  Qwen3-Omni-30B-A3B-Instruct:
    ttl: 600 
    cmd: >
      docker run --rm --name vllm-qwen3-omni-${PORT} 
      --runtime nvidia --gpus all --ipc=host --network container:llama-swap
      -e NVIDIA_DISABLE_FORWARD_COMPATIBILITY=1
      -v <LLM_ROOT_PATH>/vllm:/models/vllm 
      vllm-node:Version_1 
      vllm serve /models/vllm/Alibaba/Qwen3-Omni-30B-A3B-Instruct
      --served-model-name Qwen3-Omni-30B-A3B-Instruct
      --host ${host} --port ${PORT}
      --max-model-len 32768
      --gpu-memory-utilization 0.75
      --trust-remote-code
      --limit-mm-per-prompt '{"image": 2, "audio": 2}'
      --load-format fastsafetensors
      --enable-prefix-caching
      --tensor-parallel-size ${tensor_parallel} 
      --enable-auto-tool-choice
      --tool-call-parser qwen3_coder 
     # USE ONLY THIS PARSER FOR OMNI:
     # REMOVE --reasoning-parser qwen3
    cmdStop: "docker stop vllm-qwen3-omni-${PORT}"


  # --- is for Codeing ---
  Qwen3-Coder-Next-FP8-Dynamic:
    ttl: 3600
    readyTimeout: 1200
    cmd: >
      docker run --rm --name vllm-qwen3-coder-${PORT}
      --runtime nvidia --gpus all --ipc=host --network container:llama-swap
      -e NVIDIA_DISABLE_FORWARD_COMPATIBILITY=1
      -v /path/to/LLMs/vllm:/models/vllm
      -v /path/to/Docker/dgx-spark_lite-llm_llama-swap_vllm_llama-cpp_ollama/vllm/build/spark-vllm-docker/mods/fix-qwen3-next-autoround:/mod:ro
      --entrypoint /bin/bash
      vllm-node-tf5:latest
      -c "cd /mod && bash run.sh && python3 -m vllm.entrypoints.openai.api_server --model /models/vllm/Alibaba/Qwen3-Coder-Next-FP8-Dynamic --served-model-name Qwen3-Coder-Next-FP8-Dynamic --host ${host} --port ${PORT} --gpu-memory-utilization 0.75 --max-model-len 32768 --kv-cache-dtype fp8 --load-format fastsafetensors --attention-backend flashinfer --tensor-parallel-size 1 --enable-auto-tool-choice --tool-call-parser qwen3_coder"
     # REMOVE --reasoning-parser qwen3
    cmdStop: "docker stop vllm-qwen3-coder-${PORT}"

  # --- Optimized: 1M context, INT4 AutoRound, spark-arena v2 recipe ---
  Qwen3-Coder-Next-int4-AutoRound:
    ttl: 3600
    readyTimeout: 1200
    cmd: >
      docker run --rm --name vllm-qwen3-coder-ar-${PORT}
      --runtime nvidia --gpus all --ipc=host --network container:llama-swap
      -e NVIDIA_DISABLE_FORWARD_COMPATIBILITY=1
      -e VLLM_MARLIN_USE_ATOMIC_ADD=1
      -e VLLM_ALLOW_LONG_MAX_MODEL_LEN=1
      -e VLLM_MEMORY_PROFILER_ESTIMATE_CUDAGRAPHS=1
      -e SAFETENSORS_FAST_GPU=1
      -e VLLM_USE_FLASHINFER_MOE_FP8=1
      -v /path/to/LLMs/vllm:/models/vllm
      -v /path/to/Docker/dgx-spark_lite-llm_llama-swap_vllm_llama-cpp_ollama/vllm/build/spark-vllm-docker/mods/fix-qwen3-next-autoround:/mod:ro
      --entrypoint /bin/bash
      vllm-node-tf5:latest
      -c "cd /mod && bash run.sh && python3 -m vllm.entrypoints.openai.api_server --model /models/vllm/Alibaba/Qwen3-Coder-Next-int4-AutoRound --served-model-name Qwen3-Coder-Next-int4-AutoRound --enable-auto-tool-choice --tool-call-parser qwen3_coder --gpu-memory-utilization 0.6 --host ${host} --port ${PORT} --load-format fastsafetensors --max-model-len 32768 --language-model-only --enable-chunked-prefill --max-num-batched-tokens 49152 --max-num-seqs 384 --kv-cache-dtype fp8 --optimization-level 3 --performance-mode throughput"
     # REMOVE --reasoning-parser qwen3
    cmdStop: "docker stop vllm-qwen3-coder-ar-${PORT}"

# --- Instant Orchestrator - Blackwell Optimized FP8 ---
  Nemotron-3-Nano-4B-FP8:
    ttl: 300
    readyTimeout: 300
    checkEndpoint: "/health" 
    cmd: >
      docker run --rm --name vllm-nano4b-${PORT}
      --runtime nvidia --gpus all --ipc=host --network container:llama-swap
      -e NVIDIA_DISABLE_FORWARD_COMPATIBILITY=1
      -v /path/to/LLMs/vllm:/models/vllm
      spark-vllm:Version_1
      vllm serve /models/vllm/Nvidia/Nemotron-3-Nano-4B-FP8
      --served-model-name Nemotron-3-Nano-4B-FP8
      --host ${host} --port ${PORT}
      --gpu-memory-utilization 0.5
      --max-model-len 8192
      --kv-cache-dtype fp8
      --enforce-eager
      --trust-remote-code
      --load-format fastsafetensors
      --enable-prefix-caching
      --tool-call-parser qwen3_coder
      --reasoning-parser nemotron_v3
    cmdStop: "docker stop vllm-nano4b-${PORT}"

  # --- Works - is for Speed ---
  Nemotron-3-Nano-30B-A3B-NVFP4:
    ttl: 300
    readyTimeout: 600
    cmd: >
      docker run --rm --name vllm-nemotron-${PORT}
      --runtime nvidia --gpus all --ipc=host --network container:llama-swap
      -e NVIDIA_DISABLE_FORWARD_COMPATIBILITY=1
      -e VLLM_USE_FLASHINFER_MOE_FP4=1
      -e VLLM_FLASHINFER_MOE_BACKEND=throughput
      -v /path/to/LLMs/vllm:/models/vllm
      vllm-node:Version_1
      vllm serve /models/vllm/Nvidia/Nemotron-3-Nano-30B-A3B-NVFP4/hub/models--nvidia--NVIDIA-Nemotron-3-Nano-30B-A3B-NVFP4/snapshots/ab537beb128913d389306a4d0cc1a2097ac5a5af
      --served-model-name Nemotron-3-Nano-30B-A3B-NVFP4
      --host ${host} --port ${PORT}
      --gpu-memory-utilization 0.65
      --max-model-len 131072
      --kv-cache-dtype fp8
      --enforce-eager
      --trust-remote-code
      --quantization modelopt_fp4
      --enable-auto-tool-choice
      --tool-call-parser qwen3_coder
      --reasoning-parser-plugin /models/vllm/Nvidia/Nemotron-3-Nano-30B-A3B-NVFP4/nano_v3_reasoning_parser.py
      --reasoning-parser nano_v3
    cmdStop: "docker stop vllm-nemotron-${PORT}"

# --- NVIDIA Nemotron-3 Super (120B MoE - Blackwell Optimized NVFP4) ---
  Nemotron-3-Super-120B-A12B-NVFP4:
    ttl: 3600          
    readyTimeout: 1800 
    cmd: >
      docker run --rm --name vllm-nemotron-super-${PORT}
      --runtime nvidia --gpus all --ipc=host --network container:llama-swap --shm-size=64g
      -e NVIDIA_DISABLE_FORWARD_COMPATIBILITY=1
      -e VLLM_FLASHINFER_ALLREDUCE_BACKEND=trtllm
      -e VLLM_ALLOW_LONG_MAX_MODEL_LEN=1
      -e RAY_memory_monitor_refresh_ms=0
      -v /path/to/LLMs/vllm:/models/vllm
      spark-vllm:Version_1
      vllm serve /models/vllm/Nvidia/NVIDIA-Nemotron-3-Super-120B-A12B-NVFP4
      --served-model-name Nemotron-3-Super-120B-A12B-NVFP4
      --host ${host} --port ${PORT}
      --gpu-memory-utilization 0.7
      --tensor-parallel-size ${tensor_parallel} 
      --max-model-len 65536
      --max-num-seqs 10
      --kv-cache-dtype fp8
      --moe-backend cutlass
      --trust-remote-code
      --enable-prefix-caching
      --load-format fastsafetensors
      --tool-call-parser qwen3_coder
      --enable-auto-tool-choice
      --reasoning-parser nemotron_v3
      --mamba_ssm_cache_dtype float32
      --attention-backend TRITON_ATTN
      --distributed-executor-backend ray
    cmdStop: "docker stop vllm-nemotron-super-${PORT}"
 #    --max-model-len 262144

  # --- Works - is for Text based stuff and Coding ---
  GPT-OSS-120B:
    ttl: 3600
    readyTimeout: 1200
    cmd: >
      docker run --rm --name vllm-gptoss-${PORT} 
      --runtime nvidia --gpus all --ipc=host --network container:llama-swap
      -e NVIDIA_DISABLE_FORWARD_COMPATIBILITY=1
      -e VLLM_USE_FLASHINFER_MOE_MXFP4_MXFP8=1
      -v /path/to/LLMs/vllm:/models/vllm 
      vllm-node-mxfp4
      vllm serve /models/vllm/OpenAI/GPT-OSS-120B/hub/models--openai--gpt-oss-120b/snapshots/b5c939de8f754692c1647ca79fbf85e8c1e70f8a
      --served-model-name GPT-OSS-120B
      --host ${host} --port ${PORT}
      --gpu-memory-utilization 0.7
      --tensor-parallel-size ${tensor_parallel} 
      --load-format fastsafetensors
      --quantization mxfp4
      --kv-cache-dtype fp8
      --max-num-batched-tokens 8192
      --enable-prefix-caching
      --tool-call-parser openai
      --reasoning-parser openai_gptoss
      --enable-auto-tool-choice
    cmdStop: "docker stop vllm-gptoss-${PORT}"

  # --- Works - is for fast Roleplay or Text based Stuff ---
  Mistral-Small-24B-Instruct-2501:
    ttl: 600
    cmd: >
      docker run --rm --name vllm-mistral-small-${PORT} 
      --runtime nvidia --gpus all --ipc=host --network container:llama-swap
      -e NVIDIA_DISABLE_FORWARD_COMPATIBILITY=1
      -v /path/to/LLMs/vllm:/models/vllm 
      vllm-node:Version_1
      vllm serve /models/vllm/Mistral/Mistral-Small-24B-Instruct-2501
      --served-model-name Mistral-Small-24B-Instruct-2501
      --host ${host} --port ${PORT}
      --gpu-memory-utilization ${gpu_mem}
      --max-model-len 32768
      --trust-remote-code
      --tensor-parallel-size ${tensor_parallel} 
      --enforce-eager
      --enable-auto-tool-choice
      --tool-call-parser mistral
    cmdStop: "docker stop vllm-mistral-small-${PORT}"

  # --- Work in progress vllm version Leads to crash cause not enough RAM ---
#  MiniMax-M2.5-BF16-INT4-AWQ:
#    ttl: 600
