# --- GITHUB / REGISTRY SETTINGS ---
# Your GitHub username (used as default image namespace)
GH_USER=your-github-username

# Container registry to pull/push images from.
# Default: ghcr.io  — override for GitLab, Harbor, AWS ECR, etc.
REGISTRY=ghcr.io

# Image namespace within the registry (defaults to GH_USER if unset).
# GitHub:  your-github-username or use martin-b78
# GitLab:  mygroup/myproject
IMAGE_NAMESPACE=martin-b78

# --- REGISTRY AUTH ---
# GitHub Personal Access Token (read:packages to pull, write:packages to push)
GITHUB_TOKEN=ghp_your-token-here

# Tag used when building/pushing images (build_and_push.sh)
IMAGE_TAG=latest

# --- PATHS ---
# Root folder for all model files
LLM_ROOT_PATH=/home/user/LLMs
# Local path to this repository clone
REPO_CONFIG_PATH=/home/user/Docker/dgx-spark_lite-llm_llama-swap_vllm_llama-cpp_ollama

# --- LITELLM / DATABASE ---
LITELLM_MASTER_KEY=sk-choose-a-secure-key
POSTGRES_DB=litellm
POSTGRES_USER=litellm_admin
POSTGRES_PASSWORD=choose-a-db-password
# Keep DATABASE_URL in sync with POSTGRES_USER, POSTGRES_PASSWORD, and POSTGRES_DB above
DATABASE_URL="postgresql://litellm_admin:choose-a-db-password@litellm-db:5432/litellm"
LITELLM_UI_USERNAME=admin
LITELLM_UI_PASSWORD=choose-a-ui-password

# --- HARDWARE & BUILD ---
# SM121 is for Blackwell GB10 (used by build_and_push.sh)
CUDA_ARCH=121
# Docker network name (used by setup scripts)
EXTERNAL_NETWORK_NAME=dgx_net
