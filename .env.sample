# --- GITHUB SETTINGS ---
# Your GitHub username (where images will be hosted)
GH_USER=your-github-username
IMAGE_TAG=latest

# --- PATHS ---
# Root folder for all model files
LLM_ROOT_PATH=/home/user/LLMs
# Local path to this repository
REPO_CONFIG_PATH=/home/user/Docker/dgx-spark_master_stack

# --- LITELLM / DATABASE ---
LITELLM_MASTER_KEY=sk-choose-a-secure-key
POSTGRES_PASSWORD=choose-a-db-password
DATABASE_URL="postgresql://litellm_admin:choose-a-db-password@127.0.0.1:15432/litellm"

# --- HARDWARE & NETWORK ---
# SM121 is for Blackwell GB10
CUDA_ARCH=121
EXTERNAL_NETWORK_NAME=dgx_net
