  # ===================================================
  # 🎭 CLAUDE CODE COMPATIBILITY LAYER
  # ===================================================
  - model_name: claude-3-5-sonnet-20241022
    litellm_params:
      model: openai/GLM-4.6-derestricted
      api_base: "http://ollama:11434"
      api_key: "sk-your-litellm-master-key"

  - model_name: qwen-3-coder-30b-fp8
    litellm_params:
