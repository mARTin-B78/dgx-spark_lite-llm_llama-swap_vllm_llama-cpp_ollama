  # - model_name: qwen-3-coder-30b-fp8
  #   litellm_params:
  #     model: openai/Qwen/Qwen3-Coder-30B-A3B-Instruct-FP8
  #     api_base: "http://ollama:11434/v1"
  #     api_key: "no-key"
  #     drop_params: true

  # ===================================================
  # 🦙 OLLAMA (Local & Proxy)
  # ===================================================

  # - model_name: dolphin-mistral-24b
  #   litellm_params:
  #     model: openai/ikiru/dolphin-mistral-24b-venice-edition:latest
  #     api_base: "http://llama-swap:8080/v1"
  #     api_key: "no-key"

litellm_settings:
  drop_params: true
  set_verbose: false
  request_timeout: 900
  merge_reasoning_content_in_choices: true
  stream: true
  # Prevent LiteLLM from health-checking all models on startup —
  # that would trigger llama-swap to load every model simultaneously.
  health_check_interval: 0
  # Never retry or fall back to another model on timeout/failure;
  # let the caller decide what to do.
  num_retries: 0
  fallbacks: []
# stream_timeout: 5
# database_url: "postgresql://litellm_admin:LiteLLM-PostGres-PW@litellm-db:5432/litellm"
