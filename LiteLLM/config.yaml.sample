      merge_reasoning_content_in_choices: true

  # --- NVIDIA Nemotron-3 Nano-Omni (Multimodal: text + image + audio, FP8) ---
  # - model_name: Nemotron-3-Nano-Omni-30B-A3B-Reasoning-FP8
  #   litellm_params:
  #     model: openai/Nemotron-3-Nano-Omni-30B-A3B-Reasoning-FP8
  #     api_base: "http://llama-swap:8080/v1"
