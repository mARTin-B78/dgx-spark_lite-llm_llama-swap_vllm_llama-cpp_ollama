litellm_settings:
  drop_params: true
  set_verbose: false
  request_timeout: 900
  merge_reasoning_content_in_choices: true
  stream: true
  # Prevent LiteLLM from health-checking all models on startup —
  # that would trigger llama-swap to load every model simultaneously.
  health_check_interval: 0
  # Never retry or fall back to another model on timeout/failure;
  # let the caller decide what to do.
  num_retries: 0
  fallbacks: []
# stream_timeout: 5
# database_url: "postgresql://litellm_admin:LiteLLM-PostGres-PW@litellm-db:5432/litellm"
